---
import { BENTO } from '../content/site';
import Reveal from './Reveal.astro';
---

<section class="section" id="plataforma">
  <div class="wrap">
    <Reveal>
      <div class="section-header center">
        <span class="eyebrow">Plataforma</span>
        <h2>No solo interfaces: infraestructura municipal seria</h2>
        <p class="lead">
          Tiempo real, gemelo territorial, seguridad, mobile y APIs — la capa que sostiene cada módulo
          del ecosistema.
        </p>
      </div>
    </Reveal>

    <div class="bento-grid">
      {BENTO.map((cell) => (
        <Reveal>
          <article class="bento-cell surface">
            {cell.badge && <span class="bento-badge">{cell.badge}</span>}
            <h3>{cell.title}</h3>
            {cell.metric && <div class="bento-metric">{cell.metric}</div>}
            <p>{cell.description}</p>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
