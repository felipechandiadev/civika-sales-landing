---
type Props = {
  size?: number;
  class?: string;
  glow?: boolean;
};

const { size = 64, class: className = '', glow = true } = Astro.props;
---

<span
  class:list={['lira-mark', glow && 'lira-mark--glow', className]}
  style={`width: ${size}px; height: ${size}px`}
  aria-hidden="true"
></span>
