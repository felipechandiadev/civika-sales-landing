---
import Reveal from './Reveal.astro';
---

<section class="logo-showcase section-tight" aria-label="Marca CIVIKA">
  <div class="wrap">
    <Reveal>
      <div class="logo-showcase__inner">
        <div class="logo-showcase__halo" aria-hidden="true"></div>
        <div class="logo-showcase__ring" aria-hidden="true"></div>
        <img class="logo-showcase__mark" src="/logo-svg.svg" alt="CIVIKA" width="320" height="320" />
      </div>
    </Reveal>
  </div>
</section>
