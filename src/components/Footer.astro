---
import { CTA, NAV, SITE } from '../content/site';
---

<footer class="site-footer" id="contacto">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <img src="/logo-svg.svg" alt="" width="40" height="40" />
      <strong>{SITE.name}</strong>
      <p>{SITE.tagline}</p>
    </div>

    <div class="footer-links">
      <strong>Navegación</strong>
      {NAV.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="footer-links">
      <strong>Contacto</strong>
      <a href={CTA.primary.href}>{CTA.primary.label}</a>
      <a href="https://civika.sbs" target="_blank" rel="noopener noreferrer">civika.sbs</a>
    </div>
  </div>

  <div class="wrap footer-bottom">
    © {new Date().getFullYear()} {SITE.name} — Plataforma municipal integrada.
  </div>
</footer>
