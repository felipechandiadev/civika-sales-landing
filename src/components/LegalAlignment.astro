---
import { COMPLIANCE } from '../content/site';
import Reveal from './Reveal.astro';
---

<section class="section" id="ley">
  <div class="wrap">
    <Reveal>
      <div class="section-header">
        <span class="eyebrow">{COMPLIANCE.eyebrow}</span>
        <h2>{COMPLIANCE.title}</h2>
        <p class="lead">{COMPLIANCE.intro}</p>
      </div>
    </Reveal>

    <div class="compliance-grid">
      {COMPLIANCE.pillars.map((pillar) => (
        <Reveal>
          <article class="compliance-card surface">
            <span class="compliance-law">{pillar.law}</span>
            <h3>{pillar.title}</h3>
            <p>{pillar.summary}</p>
            <div class="module-highlights">
              {pillar.apps.map((app) => (
                <span class="chip">{app}</span>
              ))}
            </div>
          </article>
        </Reveal>
      ))}
    </div>

    <Reveal>
      <div class="compliance-focus surface">
        <span class="eyebrow">Focus · gestión operativa</span>
        <p class="lead">{COMPLIANCE.focusHighlight}</p>
        <p>{COMPLIANCE.note}</p>
      </div>
    </Reveal>
  </div>
</section>
