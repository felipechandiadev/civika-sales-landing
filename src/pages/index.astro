---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Reveal from '../components/Reveal.astro';
import Marquee from '../components/Marquee.astro';
import LayersStack from '../components/LayersStack.astro';
import EcosystemDiagram from '../components/EcosystemDiagram.astro';
import StickyPillars from '../components/StickyPillars.astro';
import ModulesGrid from '../components/ModulesGrid.astro';
import IndicatorsSection from '../components/IndicatorsSection.astro';
import LogoShowcase from '../components/LogoShowcase.astro';
import LegalAlignment from '../components/LegalAlignment.astro';
import BentoPlatform from '../components/BentoPlatform.astro';
import { HeroMockup } from '../components/HeroMockup';
import { CTA, HERO, SITE } from '../content/site';
---

<Layout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>
  <div class="hero-glow" aria-hidden="true"></div>
  <Header />

  <main>
    <section class="section hero" id="intro">
      <div class="wrap hero-grid">
        <Reveal>
          <div class="hero-copy">
            <span class="badge">
              <span class="badge-dot"></span>
              {HERO.badge}
            </span>
            <h1>{HERO.title}</h1>
            <p class="lead">{HERO.subtitle}</p>
            <div class="hero-actions">
              <a class="btn btn-primary" href={HERO.secondaryCta.href}>{HERO.secondaryCta.label}</a>
            </div>
          </div>
        </Reveal>

        <Reveal>
          <HeroMockup client:load />
        </Reveal>
      </div>
    </section>

    <Marquee />
    <LogoShowcase />
    <LayersStack />
    <EcosystemDiagram />
    <StickyPillars />
    <ModulesGrid />
    <IndicatorsSection />
    <LegalAlignment />
    <BentoPlatform />

    <section class="cta-section" id="demo">
      <div class="wrap">
        <Reveal>
          <h2>{CTA.title}</h2>
          <p class="lead">{CTA.body}</p>
          <div class="cta-actions">
            <a class="btn btn-primary" href={CTA.primary.href}>{CTA.primary.label}</a>
            <a class="btn btn-ghost" href={CTA.secondary.href}>{CTA.secondary.label}</a>
          </div>
        </Reveal>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
